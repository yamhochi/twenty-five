---
import type { CollectionEntry } from "astro:content";

import FormattedDate from "@/components/FormattedDate.astro";
import WebMentions from "@/components/blog/webmentions/index.astro";
import BasePostLayout from "./BasePost.astro";

interface Props {
	post: CollectionEntry<"post">;
}

const { post } = Astro.props;
const {
	data: {
		company,
		description,
		duration,
		gated,
		ogImage,
		outcome,
		publishDate,
		role,
		service,
		tags,
		title,
		updatedDate,
	},
	slug,
} = post;

const socialImage = ogImage ?? `/og-image/${slug}.png`;
const articleDate = updatedDate?.toISOString() ?? publishDate.toISOString();
const { headings, remarkPluginFrontmatter } = await post.render();

const dateTimeOptions: Intl.DateTimeFormatOptions = { month: "long" };
const formEndpoint = import.meta.env.PUBLIC_FORMSPREE_ENDPOINT ?? "";
const tocHeadings = headings.filter((h) => h.depth <= 2);
---

<BasePostLayout meta={{ articleDate, description, ogImage: socialImage, title }}>
	<!-- Integrated hero: flush against the nav, no gap -->
	<div
		id="post-hero"
		class="-mdivide-y rounded-xl border border-accent-2/5 bg-accent/5 py-12 sm:-mx-8"
	>
		<div class="px-4 sm:px-8">
			<!-- Breadcrumb -->
			<p class="text-textColor/6 0 font-mono text-xs uppercase tracking-widest">
				<a href="/#work" class="transition-colors hover:text-textColor/60">Work</a>
				<span class="mx-2">/</span>
				{company ?? title}
			</p>

			<!-- Title row with outcome callout -->
			<div class="flex items-end gap-12 pb-10 pt-5">
				<div class="flex-1">
					<h1 class="title-post mb-4 max-w-md">{company}</h1>
					<p class="max-w-md text-xl leading-relaxed text-textColor/80">{title} - {description}</p>
					<p class="mt-3 text-sm text-textColor/60">
						<FormattedDate date={publishDate} dateTimeOptions={dateTimeOptions} />
						{" / "}{remarkPluginFrontmatter.minutesRead}
					</p>
				</div>
			</div>

			<div class="border-t border-accent-2/5"></div>

			<!-- Metadata strip -->
			{
				(company || role || duration || service || outcome) && (
					<div class="flex flex-wrap gap-24 py-4">
						{company && (
							<div>
								<p class="mb-0.5 font-mono text-xs uppercase tracking-widest text-textColor/60">
									Company
								</p>
								<p class="text-sm font-medium text-accent">{company}</p>
							</div>
						)}
						{role && (
							<div>
								<p class="mb-0.5 font-mono text-xs uppercase tracking-widest text-textColor/60">
									Role
								</p>
								<p class="text-sm font-medium text-accent">{role}</p>
							</div>
						)}
						{duration && (
							<div>
								<p class="mb-0.5 font-mono text-xs uppercase tracking-widest text-textColor/60">
									Duration
								</p>
								<p class="text-sm font-medium text-accent">{duration}</p>
							</div>
						)}
						{service && (
							<div>
								<p class="mb-0.5 font-mono text-xs uppercase tracking-widest text-textColor/60">
									Service
								</p>
								<p class="text-sm font-medium text-accent">{service}</p>
							</div>
						)}
						{outcome && (
							<div>
								<p class="mb-0.5 font-mono text-xs uppercase tracking-widest text-textColor/60">
									Outcome
								</p>
								<p class="text-sm font-medium text-accent">{outcome}</p>
							</div>
						)}
					</div>
				)
			}
		</div>
	</div>

	<!-- Two-col body: sticky left nav + article -->
	<div class="flex items-start gap-16 py-12">
		<!-- LEFT: sticky section nav -->
		{
			tocHeadings.length > 0 && (
				<aside class="sticky top-8 hidden w-80 shrink-0 self-start border-t border-accent-2/10 pt-6 lg:block">
					<nav id="aside-toc">
						<p class="mb-3 font-mono text-xs uppercase tracking-widest text-textColor/80">
							Contents
						</p>
						<ul class="space-y-1">
							{tocHeadings.map((h) => (
								<li>
									<a
										href={`#${h.slug}`}
										class:list={[
											"aside-toc-link block rounded px-2 py-1.5 text-sm font-medium text-textColor/80 transition-colors hover:bg-accent/5 hover:text-accent",
											h.depth === 3 && "pl-3 text-xs",
										]}
									>
										{h.text}
									</a>
								</li>
							))}
						</ul>
					</nav>

					{tags.length > 0 && (
						<div class="mt-8 border-t border-accent-2/10 pt-6">
							<p class="mb-2 font-mono text-xs uppercase tracking-widest text-textColor/50">Tags</p>
							<div class="flex flex-wrap gap-1.5">
								{tags.map((tag) => (
									<a
										href={`/tags/${tag}/`}
										class="rounded-md border border-zinc-800 px-2 py-0.5 text-xs text-textColor/50 transition-colors hover:text-accent"
									>
										#{tag}
									</a>
								))}
							</div>
						</div>
					)}
				</aside>
			)
		}

		<!-- RIGHT: article content -->
		<article class="min-w-0 flex-1" data-pagefind-body>
			<div
				class="prose prose-cactus max-w-none text-gray-600 prose-headings:font-semibold prose-headings:text-accent-2 dark:text-[#ededed] sm:prose-th:before:content-none"
			>
				<slot />
				<WebMentions />
			</div>
		</article>
	</div>

	<!-- Gated access modal -->
	{
		gated && (
			<div
				id="gate-overlay"
				data-endpoint={formEndpoint}
				class="fixed inset-0 z-50 hidden items-center justify-center bg-black/60 backdrop-blur-sm"
				aria-modal="true"
				role="dialog"
				aria-labelledby="gate-title"
			>
				<div class="mx-4 w-full max-w-sm rounded-2xl border border-accent-2/10 bg-bgColor p-8 shadow-2xl">
					<p class="text-textColor/460 mb-1 font-mono text-xs uppercase tracking-widest">
						Restricted
					</p>
					<h2 id="gate-title" class="mb-2 font-custom-styled text-xl font-bold text-textColor">
						Request access
					</h2>
					<p class="mb-6 text-sm leading-relaxed text-textColor/80">
						This case study contains confidential details. Leave your email and I'll get back to you
						shortly.
					</p>

					<form id="gate-form" novalidate>
						<label for="gate-email" class="mb-1.5 block text-xs font-medium text-textColor/60">
							Email address
						</label>
						<input
							id="gate-email"
							name="email"
							type="email"
							required
							placeholder="you@example.com"
							class="mb-4 w-full rounded-lg border border-accent-2/20 bg-accent/5 px-4 py-2.5 text-sm text-textColor placeholder-textColor/30 outline-none focus:border-accent/50 focus:ring-1 focus:ring-accent/30"
						/>
						<label for="gate-message" class="mb-1.5 block text-xs font-medium text-textColor/60">
							Message
						</label>
						<textarea
							id="gate-message"
							name="message"
							rows="3"
							placeholder="Tell me a bit about yourself and what brought you here…"
							class="mb-4 w-full resize-none rounded-lg border border-accent-2/20 bg-accent/5 px-4 py-2.5 text-sm text-textColor placeholder-textColor/30 outline-none focus:border-accent/50 focus:ring-1 focus:ring-accent/30"
						/>
						<button
							type="submit"
							id="gate-submit"
							class="w-full rounded-lg bg-accent px-4 py-2.5 text-sm font-semibold text-bgColor transition-opacity hover:opacity-90 disabled:opacity-50"
						>
							Request access
						</button>
						<p id="gate-error" class="mt-2 hidden text-xs text-red-400" />
					</form>

					<div id="gate-success" class="hidden text-center">
						<p class="mb-1 text-2xl">✓</p>
						<p class="text-sm font-medium text-textColor">Request sent</p>
						<p class="mt-1 text-xs text-textColor/50">I'll review and be in touch soon.</p>
						<a
							href="/"
							class="mt-5 inline-block w-full rounded-lg bg-white px-4 py-2.5 text-sm font-semibold text-black transition-opacity hover:opacity-90"
						>
							← Back to homepage
						</a>
					</div>
				</div>
			</div>
		)
	}

	<!-- Back to top -->
	<button
		aria-label="Back to Top"
		class="z-90 fixed bottom-8 end-4 flex h-10 w-10 translate-y-28 items-center justify-center rounded-full border-2 border-transparent bg-zinc-200 text-3xl opacity-0 transition-all duration-300 hover:border-zinc-400 data-[show=true]:translate-y-0 data-[show=true]:opacity-100 dark:bg-zinc-700 sm:end-8 sm:h-12 sm:w-12"
		data-show="false"
		id="to-top-btn"
	>
		<svg
			aria-hidden="true"
			class="h-6 w-6"
			fill="none"
			focusable="false"
			stroke="currentColor"
			stroke-width="2"
			viewBox="0 0 24 24"
			xmlns="http://www.w3.org/2000/svg"
		>
			<path d="M4.5 15.75l7.5-7.5 7.5 7.5" stroke-linecap="round" stroke-linejoin="round"></path>
		</svg>
	</button>
</BasePostLayout>

<script>
	// Back to top
	const scrollBtn = document.getElementById("to-top-btn") as HTMLButtonElement;
	const targetHeader = document.getElementById("post-hero") as HTMLDivElement;

	scrollBtn?.addEventListener("click", () => {
		document.documentElement.scrollTo({ behavior: "smooth", top: 0 });
	});

	if (targetHeader && scrollBtn) {
		new IntersectionObserver((entries) => {
			entries.forEach((entry) => {
				scrollBtn.dataset.show = (!entry.isIntersecting).toString();
			});
		}).observe(targetHeader);
	}

	// Active TOC highlight
	const tocLinks = document.querySelectorAll<HTMLAnchorElement>(".aside-toc-link");
	let activeId = "";

	const setActive = (id: string) => {
		if (id === activeId) return;
		activeId = id;
		tocLinks.forEach((link) => {
			const isActive = link.getAttribute("href") === `#${id}`;
			link.classList.toggle("text-accent", isActive);
			link.classList.toggle("bg-textColor/10", isActive);
			link.classList.toggle("text-textColor/80", !isActive);
		});
	};

	const observer = new IntersectionObserver(
		(entries) => {
			entries.forEach((entry) => {
				if (entry.isIntersecting) setActive(entry.target.id);
			});
		},
		{ rootMargin: "-10% 0px -85% 0px", threshold: 0 },
	);

	tocLinks.forEach((link) => {
		const id = link.getAttribute("href")?.slice(1);
		if (id) {
			const el = document.getElementById(id);
			if (el) observer.observe(el);
		}
	});
</script>

<script>
	// Only activates when the gate overlay is present in the DOM
	const overlay = document.getElementById("gate-overlay");
	if (overlay) {
		const FORM_ENDPOINT = overlay.dataset.endpoint ?? "";
		const form = document.getElementById("gate-form") as HTMLFormElement | null;
		const emailInput = document.getElementById("gate-email") as HTMLInputElement | null;
		const messageInput = document.getElementById("gate-message") as HTMLTextAreaElement | null;
		const submitBtn = document.getElementById("gate-submit") as HTMLButtonElement | null;
		const errorMsg = document.getElementById("gate-error");
		const successMsg = document.getElementById("gate-success");

		const showGate = () => {
			overlay.classList.remove("hidden");
			overlay.classList.add("flex");
			document.body.style.overflow = "hidden";
		};

		const article = document.querySelector("article[data-pagefind-body]");
		const headings = article ? Array.from(article.querySelectorAll("h2, h3")) : [];
		const trigger = headings[1] ?? headings[0];

		if (trigger) {
			new IntersectionObserver(
				(entries) => {
					if (entries[0]?.isIntersecting) showGate();
				},
				{ rootMargin: "0px 0px -80% 0px", threshold: 0 },
			).observe(trigger);
		}

		form?.addEventListener("submit", async (e) => {
			e.preventDefault();
			if (!emailInput?.value || !emailInput.validity.valid) {
				if (errorMsg) {
					errorMsg.textContent = "Please enter a valid email address.";
					errorMsg.classList.remove("hidden");
				}
				return;
			}

			if (errorMsg) errorMsg.classList.add("hidden");
			if (submitBtn) {
				submitBtn.disabled = true;
				submitBtn.textContent = "Sending…";
			}

			try {
				if (FORM_ENDPOINT) {
					await fetch(FORM_ENDPOINT, {
						method: "POST",
						headers: { "Content-Type": "application/json", Accept: "application/json" },
						body: JSON.stringify({
							email: emailInput.value,
							message: messageInput?.value ?? "",
							page: window.location.href,
						}),
					});
				}
				form.classList.add("hidden");
				successMsg?.classList.remove("hidden");
			} catch {
				if (submitBtn) {
					submitBtn.disabled = false;
					submitBtn.textContent = "Request access";
				}
				if (errorMsg) {
					errorMsg.textContent = "Something went wrong. Try again.";
					errorMsg.classList.remove("hidden");
				}
			}
		});
	}
</script>
