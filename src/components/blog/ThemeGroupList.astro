---
import type { CollectionEntry } from "astro:content";
import { getPostSortDate } from "@/data/post";

type Props = {
	posts: CollectionEntry<"post">[];
	description?: string;
};

const { posts } = Astro.props;
const [featured] = posts;
---

<div class="flex flex-col overflow-hidden sm:grid sm:gap-4" style="grid-template-columns: 38% 1fr;">
	<!-- Theme image — first post's cover image -->
	{
		featured?.data.coverImage && (
			<div class="aspect-[33/29] sm:aspect-auto overflow-hidden">
				<img
					src={featured.data.coverImage.src}
					alt={featured.data.coverImage.alt}
					class="h-full w-full object-cover sm:h-[330px]"
					loading="lazy"
				/>
			</div>
		)
	}

	<!-- Project list -->
	<div class="bg-bgColor">
		<!-- Projects -->
		{
			posts.map((post) => {
				const year = getPostSortDate(post).getFullYear();
				return (
					<a
						href={`/posts/${post.slug}/`}
						rel="prefetch"
						class="group block border-b border-accent-2/10 px-3 py-4 transition-colors last:border-b-0 hover:bg-accent-2/[0.03]"
					>
						<div class="mb-1 font-custom-styled text-xs font-semibold uppercase tracking-widest text-textColor/35">
							{post.data.company && `${post.data.company} · `}
							{year}
						</div>
						<h4 class="font-custom-styled text-sm font-semibold leading-snug text-accent-2 transition-colors group-hover:text-accent">
							{post.data.title}
						</h4>
						<p class="mt-1 text-xs leading-relaxed text-textColor/50">{post.data.description}</p>
					</a>
				);
			})
		}
	</div>
</div>
