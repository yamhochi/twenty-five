---
import type { CollectionEntry } from "astro:content";
import { getPostSortDate } from "@/data/post";
import FormattedDate from "../FormattedDate.astro";

type Props = {
	post: CollectionEntry<"post">;
};

const { post } = Astro.props;
const postDate = getPostSortDate(post);
---

<article
	class="group overflow-hidden rounded-lg border border-accent-2/10 bg-bgColor transition-colors hover:border-accent-2/25"
>
	<a href={`/posts/${post.slug}/`} rel="prefetch" class="block">
		{
			post.data.coverImage && (
				<div class="aspect-video overflow-hidden border-b border-accent-2/10">
					<img
						src={post.data.coverImage.src}
						alt={post.data.coverImage.alt}
						class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-[1.01]"
						loading="eager"
					/>
				</div>
			)
		}
		<div class="p-5 sm:p-6">
			<div class="mb-3 flex flex-wrap items-center gap-2">
				{
					post.data.outcome && (
						<span class="inline-flex items-center rounded-full border border-accent/20 bg-accent/5 px-2.5 py-0.5 font-custom-styled text-xs font-semibold text-accent">
							↑ {post.data.outcome}
						</span>
					)
				}
				<span class="font-custom-styled text-xs text-textColor/40">
					<FormattedDate date={postDate} />
					{post.data.company && <> &middot; {post.data.company}</>}
				</span>
			</div>
			<h3
				class="mb-2 font-custom-styled text-xl font-semibold leading-snug text-accent-2 transition-colors group-hover:text-accent"
			>
				{post.data.title}
			</h3>
			<p class="text-sm leading-relaxed text-textColor/70">{post.data.description}</p>
		</div>
	</a>
</article>
