---
import type { CollectionEntry } from "astro:content";
import { getPostSortDate } from "@/data/post";

type Props = {
	post: CollectionEntry<"post">;
	index: number;
};

const { post, index } = Astro.props;
const imgLeft = index % 2 === 0;
const year = getPostSortDate(post).getFullYear();
---

<a
	href={`/posts/${post.slug}/`}
	rel="prefetch"
	class="group grid overflow-hidden rounded-lg border border-accent-2/10 transition-colors hover:border-accent-2/25"
	style={imgLeft ? "grid-template-columns: 55% 45%;" : "grid-template-columns: 45% 55%;"}
>
	{
		post.data.coverImage && (
			<div class:list={["overflow-hidden", !imgLeft && "order-2"]}>
				<img
					src={post.data.coverImage.src}
					alt={post.data.coverImage.alt}
					class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-[1.01]"
					loading="eager"
				/>
			</div>
		)
	}
	<div
		class:list={[
			"flex flex-col justify-center bg-bgColor p-6 sm:p-8",
			!imgLeft && "order-1",
		]}
	>
		<div class="mb-2 font-custom-styled text-xs font-semibold uppercase tracking-widest text-textColor/35">
			{post.data.company}{post.data.company && " · "}{year}
		</div>
		<h3
			class="mb-3 font-custom-styled text-lg font-semibold leading-snug text-accent-2 transition-colors group-hover:text-accent sm:text-xl"
		>
			{post.data.title}
		</h3>
		<p class="mb-4 text-sm leading-relaxed text-textColor/60">{post.data.description}</p>
		{
			post.data.outcome && (
				<span class="self-start inline-flex items-center rounded-full border border-accent/20 bg-accent/5 px-2.5 py-0.5 font-custom-styled text-xs font-semibold text-accent">
					↑ {post.data.outcome}
				</span>
			)
		}
	</div>
</a>
