---
import type { CollectionEntry } from "astro:content";
import { getPostSortDate } from "@/data/post";

type Props = {
	post: CollectionEntry<"post">;
	index: number;
	noAlternate?: boolean;
};

const { post, index, noAlternate } = Astro.props;
const imgLeft = noAlternate ? true : index % 2 === 0;
const year = getPostSortDate(post).getFullYear();
---

<a
	href={`/posts/${post.slug}/`}
	rel="prefetch"
	class="group flex flex-col transition-colors sm:grid sm:gap-4"
	style={imgLeft ? "grid-template-columns: 55% 45%;" : "grid-template-columns: 45% 55%;"}
>
	{
		post.data.coverImage && (
			<div
				class:list={[
					"aspect-[493/400] sm:aspect-auto overflow-hidden rounded transition-all duration-300 group-hover:scale-[1.02] group-hover:shadow-[0_16px_40px_rgba(0,0,0,0.1)]",
					!imgLeft && "sm:order-2",
				]}
			>
				<img
					src={post.data.coverImage.src}
					alt={post.data.coverImage.alt}
					class="h-full w-full object-cover sm:h-[400px]"
					loading="eager"
				/>
			</div>
		)
	}
	<div
		class:list={[
			"flex flex-col justify-center bg-bgColor px-2 py-6 transition-colors sm:p-8",
			!imgLeft && "sm:order-1",
		]}
	>
		<div
			class="mb-2 font-custom-styled text-xs font-semibold uppercase tracking-widest text-textColor/35"
		>
			{post.data.company}{post.data.company && " · "}{year}
		</div>
		<h3
			class="mb-3 font-custom-styled text-lg font-semibold leading-snug text-accent-2 transition-colors group-hover:text-accent sm:text-xl"
		>
			{post.data.title}
		</h3>
		<p class="mb-4 text-sm leading-relaxed text-textColor/60">{post.data.description}</p>
		{
			post.data.outcome && (
				<span class="inline-flex items-center self-start rounded-full border border-accent/20 bg-accent/5 px-2.5 py-0.5 font-custom-styled text-xs font-semibold text-accent">
					{post.data.outcome}
				</span>
			)
		}
	</div>
</a>
