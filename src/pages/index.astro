---
import SocialList from "@/components/SocialList.astro";
import ProjectAlternatingRow from "@/components/blog/ProjectAlternatingRow.astro";
import ThemeGroupList from "@/components/blog/ThemeGroupList.astro";
import { getAllPosts, sortMDByDate } from "@/data/post";
import PageLayout from "@/layouts/Base.astro";

const allPosts = await getAllPosts();
const allPostsByDate = sortMDByDate(allPosts);

const fintechPosts  = allPostsByDate.filter((p) => p.data.theme === "fintech");
const analyticsPosts = allPostsByDate.filter((p) => p.data.theme === "analytics");
const consumerPosts  = allPostsByDate.filter((p) => p.data.theme === "consumer");

const themes = [
	{
		id: "fintech",
		label: "Fintech & Regulatory",
		posts: fintechPosts,
		type: "alternating" as const,
	},
	{
		id: "analytics",
		label: "Analytics & Intelligence",
		posts: analyticsPosts,
		type: "grouped" as const,
		description:
			"Data visualisation, spatial tools, and analytical intelligence across enterprise and government contexts.",
	},
	{
		id: "consumer",
		label: "Consumer Apps",
		posts: consumerPosts,
		type: "grouped" as const,
		description:
			"Publishing platforms, media products, and subscription experiences designed for everyday audiences.",
	},
];
---

<PageLayout meta={{ title: "Home" }}>
	<!-- Bio -->
	<section>
		<span
			class="mb-5 inline-block rounded-full border border-accent/20 bg-accent/5 px-3 py-1 font-custom-styled text-xs font-bold uppercase tracking-[1.2px] text-accent"
		>
			Lead Product Designer · B2B · FinTech
		</span>
		<p class="mt-5 font-custom-styled text-[20px] font-medium leading-[2] text-textColor">
			👋🏻 I'm Andie, I help software teams figure out where their customers struggle and where new
			opportunities lie, transforming those gaps into solutions that feel simple, trusted, and worth
			paying for.
		</p>
		<p class="mb-5 mt-3 font-custom-styled text-[20px] font-medium leading-[2] text-textColor">
			Currently at CreditorWatch, I'm helping modernise an aging platform by uncovering pathways to
			grow with an expanding audience, leveraging AI & emerging technology to rethink B2B frictions
			and experiences.
		</p>
		<SocialList />
	</section>

	<!-- Theme sections -->
	<div class="mt-12 flex flex-col gap-16">
		{
			themes.map((theme) => (
				<section aria-label={theme.label}>
					<!-- Section header -->
					<div class="mb-12 flex flex-col gap-1 border-t border-accent-2/10 pt-12">
						<div class="flex items-center gap-3">
							<h2 class="font-custom-styled text-2xl font-bold uppercase tracking-[1.4px] text-textColor">
								{theme.label}
							</h2>
							<span class="font-custom-styled text-xs text-textColor/40">
								{theme.posts.length} {theme.posts.length === 1 ? "project" : "projects"}
							</span>
						</div>
						{theme.description && (
							<p class="font-custom-styled text-xs text-textColor/40">{theme.description}</p>
						)}
					</div>

					{theme.type === "alternating" ? (
						<ul class="flex flex-col divide-y divide-accent-2/10">
							{theme.posts.map((p) => (
								<li class="py-4">
									<ProjectAlternatingRow post={p} index={0} noAlternate={true} />
								</li>
							))}
						</ul>
					) : (
						<ThemeGroupList posts={theme.posts} />
					)}
				</section>
			))
		}
	</div>
</PageLayout>
